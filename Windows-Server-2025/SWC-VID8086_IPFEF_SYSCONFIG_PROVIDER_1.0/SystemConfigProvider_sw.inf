[Version] 
Signature = "$WINDOWS NT$" 
Class = SoftwareComponent
ClassGuid = {5c4c3332-344d-483c-8739-259e934c9cc8}
Provider = %MfgName% 
CatalogFile = SystemConfigProvider_sw.cat
DriverVer = 01/17/2026,03.04.1005.0
PnpLockDown = 1

;----------------------------------------------------------------------
; File Information
;----------------------------------------------------------------------
[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
SystemConfigProvider.dll = 1


[DestinationDirs]
DefaultDestDir = 13


;-------------------------------------------------------------------------------
; Manufacturer and Models Section
;-------------------------------------------------------------------------------
[Manufacturer]
%MfgName% = MfgName,NTamd64.10.0...17763

[MfgName.NTamd64.10.0...17763]
%FriendlyName% = IpfEfProviderInstall, SWC\%ProviderComponent%

;------------------------------------------------------------------------------
; Install Sections 
;------------------------------------------------------------------------------
[IpfEfProviderInstall.NTamd64]
CopyFiles = IpfEfProvider_CopyFiles

[IpfEfProvider_CopyFiles]
SystemConfigProvider.dll

;-------------------------------------------------------------------------------
; Install Services Section
;-------------------------------------------------------------------------------
[IpfEfProviderInstall.NTAMD64.Services]
AddService = ,2

;-------------------------------------------------------------------------------
; Install Interfaces Section
;-------------------------------------------------------------------------------
[IpfEfProviderInstall.NTamd64.Interfaces]
AddInterface = %ProviderInterface%,,IpfEfProviderInstallInterface,0

[IpfEfProviderInstallInterface]
AddReg = IpfEfProviderInstallInterface_AddReg

[IpfEfProviderInstallInterface_AddReg]
HKR,,"ProviderDir",,%13%
HKR,,"ProviderPackages",,%ProviderList%


;----------------------------------------------------------------------
; Strings and Constants
;----------------------------------------------------------------------
[Strings]
ProviderInterface = "{73FDD548-3C00-4279-B021-D0655F0B1E41}"
MfgName = "Intel"
DiskName = "Intel(R) System Config IPF Extension Provider"
FriendlyName = "Intel(R) System Config IPF Extension Provider"
IpfEfProviderDescription = "Intel(R) System Config IPF Extension Provider"
ProviderComponent = "VID8086_IPFEF_SYSCONFIG_PROVIDER_1.0"
ProviderList = "SystemConfigProvider.dll"
